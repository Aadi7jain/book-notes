<%- include('partials/head', { pageTitle: 'Sign up', user: null }) %>

<main class="auth-main">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">
        <div class="nav-brand-dot"></div>
        Book Notes
      </div>
      <h1 class="auth-title">Create an account</h1>
      <p class="auth-sub">Start tracking your reading</p>
    </div>

    <% if (error) { %><p class="auth-error"><%= error %></p><% } %>

    <form action="/signup" method="POST" class="auth-form">
      <div class="field">
        <label for="name">Your name</label>
        <input id="name" name="name" type="text" class="input" required placeholder="Aadi Jain" autocomplete="name" />
      </div>
      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" class="input" required placeholder="you@example.com" autocomplete="email" />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" class="input" required placeholder="At least 8 characters" autocomplete="new-password" />
      </div>
      <button type="submit" class="btn btn--primary btn--full">Create account</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/login" class="link-teal">Log in</a></p>
  </div>
</main>

<%- include('partials/foot') %>