<%- include('partials/head', { pageTitle: 'Sign up', user: null }) %>

<div class="auth-page">

  <div class="auth-left">
    <div class="auth-left-blob"></div>
    <div class="auth-left-blob2"></div>
    <div class="auth-left-content">
      <div class="auth-brand">
        <div class="auth-brand-dot"></div>
        <span>Book Notes</span>
      </div>
      <div class="auth-left-body">
        <h2 class="auth-left-title">Start your reading journey today</h2>
        <p class="auth-left-sub">Your own private library. Every account is completely separate.</p>
        <div class="auth-feature-list">
          <div class="auth-feature">
            <span class="auth-feature-icon">&#9632;</span>
            <span>Free forever</span>
          </div>
          <div class="auth-feature">
            <span class="auth-feature-icon">&#9632;</span>
            <span>Private per account</span>
          </div>
          <div class="auth-feature">
            <span class="auth-feature-icon">&#9632;</span>
            <span>Search Open Library instantly</span>
          </div>
          <div class="auth-feature">
            <span class="auth-feature-icon">&#9632;</span>
            <span>Works on all devices</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-right">
    <div class="auth-form-wrap">
      <div class="auth-form-header">
        <h1 class="auth-title">Create an account</h1>
        <p class="auth-sub">Start tracking your reading today</p>
      </div>

      <% if (error) { %><p class="auth-error"><%= error %></p><% } %>

      <form action="/signup" method="POST" class="auth-form">
        <div class="field">
          <label for="name">Your name</label>
          <input id="name" name="name" type="text" class="input" required
                 placeholder="Aadi Jain" autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" class="input" required
                 placeholder="you@example.com" autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" class="input" required
                 placeholder="At least 8 characters" autocomplete="new-password" />
        </div>
        <button type="submit" class="btn btn--primary btn--full">Create account</button>
      </form>

      <p class="auth-switch">Already have an account? <a href="/login" class="link-teal">Log in</a></p>
    </div>
  </div>

</div>

<%- include('partials/foot') %>