<%- include('partials/head', { pageTitle: 'New password', user: null }) %>
<div class="auth-page">
  <div class="auth-left">
    <div class="auth-left-blob"></div>
    <div class="auth-left-blob2"></div>
    <div class="auth-left-content">
      <div class="auth-brand">
        <div class="auth-brand-dot"></div>
        <span>Book Notes</span>
      </div>
      <div class="auth-left-body">
        <h2 class="auth-left-title">Almost there</h2>
        <p class="auth-left-sub">Choose a strong password you haven't used before.</p>
        <div class="auth-feature-list">
          <div class="auth-feature">
            <span class="auth-feature-icon">&#9632;</span>
            <span>At least 8 characters</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-form-wrap">
      <div class="auth-form-header">
        <h1 class="auth-title">New password</h1>
        <p class="auth-sub">Must be at least 8 characters</p>
      </div>
      <% if (error) { %><p class="auth-error"><%= error %></p><% } %>
      <form action="/reset/<%= token %>" method="POST" class="auth-form">
        <div class="field">
          <label for="password">New password</label>
          <input id="password" name="password" type="password" class="input" required
                 placeholder="At least 8 characters" autocomplete="new-password" minlength="8" />
        </div>
        <button type="submit" class="btn btn--primary btn--full">Set new password</button>
      </form>
    </div>
  </div>
</div>
<%- include('partials/foot') %>